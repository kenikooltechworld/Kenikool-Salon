APP_NAME=Kenikool Salon 
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here
API_VERSION=v1

# API
API_TITLE=Salon/Spa/Gym SaaS Platform
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/database_name
DATABASE_NAME=database_name

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_DB=0
REDIS_CACHE_DB=1
REDIS_LOCK_DB=2

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672//

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_CREDENTIALS=true
CORS_METHODS=*
CORS_HEADERS=*

# Frontend
FRONTEND_URL=http://localhost:3000

# Platform Domain (for tenant subdomains)
PLATFORM_DOMAIN=localhost:3000

# Logging
LOG_LEVEL=INFO

# Termii (SMS & WhatsApp) - Sign up at termii.com
TERMII_API_KEY=your-termii-api-key
TERMII_SECRET_KEY=your-termii-secret-key
TERMII_SENDER_ID=YourSenderID
TERMII_DEVICE_ID=your-device-id
TERMII_API_URL=https://v3.api.termii.com

# Paystack (Sign up at paystack.com for Nigerian payments)
PAYSTACK_LIVE_SECRET_KEY=your-paystack-secret-key
PAYSTACK_LIVE_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret
PAYSTACK_CALLBACK_URL=https://your-domain.com/payments/booking-payment
PAYSTACK_WEBHOOK_URL=https://your-domain.com/api/v1/webhooks/paystack

# Email Configuration (Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Your Company <noreply@yourdomain.com>

# Cloudinary (Media uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ngrok Tunnel (for Paystack webhooks)
NGROK_AUTHTOKEN=your-ngrok-authtoken
